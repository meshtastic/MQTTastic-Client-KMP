# Auto-detect text files and normalize line endings
* text=auto

# Kotlin
*.kt text diff=kotlin
*.kts text diff=kotlin

# Gradle
*.properties text
gradlew text eol=lf
gradlew.bat text eol=crlf

# Generated / binary
*.jar binary
*.png binary
*.jpg binary
*.ico binary

# Yarn lock (wasmJs)
kotlin-js-store/yarn.lock linguist-generated
