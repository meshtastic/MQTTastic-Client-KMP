{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "labels": ["dependencies"],
  "semanticCommits": "disabled",
  "schedule": ["after 10pm every weekday", "before 5am every weekday", "every weekend"],
  "platformAutomerge": true,
  "automergeStrategy": "squash",
  "rebaseWhen": "conflicted",
  "packageRules": [
    {
      "description": "Group Kotlin ecosystem dependencies",
      "groupName": "Kotlin ecosystem",
      "matchPackageNames": [
        "/^org\\.jetbrains\\.kotlin:/",
        "/^org\\.jetbrains\\.kotlinx:kotlinx-coroutines/",
        "/^org\\.jetbrains\\.kotlinx:kotlinx-io/"
      ]
    },
    {
      "description": "Group Ktor ecosystem dependencies",
      "groupName": "Ktor ecosystem",
      "matchPackageNames": [
        "/^io\\.ktor:/"
      ]
    },
    {
      "description": "Group Compose ecosystem dependencies",
      "groupName": "Compose ecosystem",
      "matchPackageNames": [
        "/^org\\.jetbrains\\.compose/",
        "/^androidx\\./"
      ]
    },
    {
      "description": "Group build tool dependencies",
      "groupName": "Build tools",
      "matchPackageNames": [
        "/^com\\.diffplug\\.spotless/",
        "/^io\\.gitlab\\.arturbosch\\.detekt/",
        "/^org\\.jetbrains\\.kotlinx\\.binary-compatibility-validator/",
        "/^org\\.jetbrains\\.kotlinx:binary-compatibility-validator/",
        "/^org\\.jetbrains\\.dokka/",
        "/^org\\.jetbrains\\.kotlinx\\.kover/",
        "/^org\\.jetbrains\\.kotlinx:kover/"
      ]
    },
    {
      "description": "Track meshtastic/protobufs submodule by tagged releases",
      "matchDepTypes": ["gitSubmodule"],
      "matchPackageNames": ["protobufs"],
      "versioning": "semver",
      "automerge": false
    },
    {
      "description": "Automerge patch updates immediately via merge queue",
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "description": "Automerge minor updates for build tools via merge queue",
      "groupName": "Build tools",
      "matchUpdateTypes": ["minor"],
      "automerge": true
    },
    {
      "description": "Stabilise minor/major non-tool deps before merging",
      "matchUpdateTypes": ["minor", "major"],
      "matchPackagePatterns": [
        "^org\\.jetbrains\\.kotlin:",
        "^org\\.jetbrains\\.kotlinx:",
        "^io\\.ktor:",
        "^org\\.jetbrains\\.compose",
        "^androidx\\."
      ],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Never automerge major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ]
}
